<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Cdp1802.Gui.App"
             xmlns:local="using:Cdp1802.Gui"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Cdp1802.Gui/Themes/CosmacTheme.axaml"/>
    </Application.Styles>
</Application>