<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Cdp1802.Gui.ViewModels"
        xmlns:models="using:Cdp1802.Gui.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="860"
        x:Class="Cdp1802.Gui.Views.MainWindow"
        x:DataType="vm:Cdp1802ViewModel"
        Title="RCA CDP1802 (COSMAC) Emulator"
        Width="1280" Height="860"
        MinWidth="960" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundPrimaryBrush}">

    <Design.DataContext>
        <vm:Cdp1802ViewModel/>
    </Design.DataContext>

    <Window.KeyBindings>
        <KeyBinding Gesture="F6" Command="{Binding AssembleAndLoadCommand}"/>
        <KeyBinding Gesture="F7" Command="{Binding StepCommand}"/>
        <KeyBinding Gesture="F5" Command="{Binding RunCommand}"/>
        <KeyBinding Gesture="F9" Command="{Binding ResetCommand}"/>
    </Window.KeyBindings>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Load Binary..." Click="OnLoadFile"/>
                <MenuItem Header="_Assemble &amp; Load (F6)" Command="{Binding AssembleAndLoadCommand}"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="OnExit"/>
            </MenuItem>
            <MenuItem Header="_Examples">
                <MenuItem Header="Hello Byte" Command="{Binding LoadExampleCommand}" CommandParameter="hello"/>
                <MenuItem Header="Counter Loop" Command="{Binding LoadExampleCommand}" CommandParameter="counter"/>
                <MenuItem Header="Q Toggle" Command="{Binding LoadExampleCommand}" CommandParameter="blink"/>
                <MenuItem Header="Add / Subtract" Command="{Binding LoadExampleCommand}" CommandParameter="add_test"/>
                <MenuItem Header="Branch Demo" Command="{Binding LoadExampleCommand}" CommandParameter="branch_demo"/>
            </MenuItem>
            <MenuItem Header="_Emulation">
                <MenuItem Header="_Step (F7)" Command="{Binding StepCommand}"/>
                <MenuItem Header="_Run / Stop (F5)" Command="{Binding RunCommand}"/>
                <MenuItem Header="_Reset (F9)" Command="{Binding ResetCommand}"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Trace Log" Command="{Binding ToggleTraceCommand}"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Click="OnAbout"/>
            </MenuItem>
        </Menu>

        <Border DockPanel.Dock="Top"
                Background="{StaticResource BackgroundPanelBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,6">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <Button Classes="cosmac-toolbar" Content="▶ Step" Command="{Binding StepCommand}" ToolTip.Tip="Execute one instruction (F7)"/>
                <Button Classes="cosmac-toolbar"
                        Classes.run="{Binding !IsRunning}"
                        Classes.stop="{Binding IsRunning}"
                        Command="{Binding RunCommand}"
                        ToolTip.Tip="Run / Stop emulation (F5)">
                    <Panel>
                        <TextBlock Text="⏵ Run" IsVisible="{Binding !IsRunning}"/>
                        <TextBlock Text="⏹ Stop" IsVisible="{Binding IsRunning}"/>
                    </Panel>
                </Button>
                <Button Classes="cosmac-toolbar" Content="↺ Reset" Command="{Binding ResetCommand}" ToolTip.Tip="Reset CPU (F9)"/>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource StatusBarBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,6">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" Margin="16,0">
                    <TextBlock Text="State:" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding MachineState}"
                               Foreground="{StaticResource AccentSecondaryBrush}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" Margin="16,0">
                    <TextBlock Text="PC:" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding PcHex}"
                               Foreground="{StaticResource HighlightPcTextBrush}"
                               FontFamily="{StaticResource MonoFont}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6" Margin="16,0,0,0">
                    <TextBlock Text="Cycles:" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalCycles}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontFamily="{StaticResource MonoFont}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Margin="2"
              ColumnDefinitions="248,4,*"
              RowDefinitions="*,4,168,Auto">

            <Border Grid.Row="0" Grid.Column="0" Classes="cosmac-panel">
                <DockPanel>
                    <TextBlock Text="Registers" Classes="section-header" DockPanel.Dock="Top"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Control" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>

                            <UniformGrid Columns="2" Rows="4">
                                <Border Classes="reg-cell" Classes.changed="{Binding RegDChanged}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="D" Classes="reg-label" Width="24"/>
                                        <TextBlock Text="{Binding RegD}" Classes="reg-value"/>
                                    </StackPanel>
                                </Border>
                                <Border Classes="reg-cell" Classes.changed="{Binding RegDFChanged}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="DF" Classes="reg-label" Width="24"/>
                                        <TextBlock Text="{Binding RegDF}" Classes="reg-value"/>
                                    </StackPanel>
                                </Border>
                                <Border Classes="reg-cell" Classes.changed="{Binding RegPChanged}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="P" Classes="reg-label" Width="24"/>
                                        <TextBlock Text="{Binding RegP}" Classes="reg-value"/>
                                    </StackPanel>
                                </Border>
                                <Border Classes="reg-cell" Classes.changed="{Binding RegXChanged}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="X" Classes="reg-label" Width="24"/>
                                        <TextBlock Text="{Binding RegX}" Classes="reg-value"/>
                                    </StackPanel>
                                </Border>
                                <Border Classes="reg-cell" Classes.changed="{Binding RegTChanged}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="T" Classes="reg-label" Width="24"/>
                                        <TextBlock Text="{Binding RegT}" Classes="reg-value"/>
                                    </StackPanel>
                                </Border>
                                <Border Classes="reg-cell" Classes.changed="{Binding RegQChanged}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="Q" Classes="reg-label" Width="24"/>
                                        <TextBlock Text="{Binding RegQ}" Classes="reg-value"/>
                                    </StackPanel>
                                </Border>
                                <Border Classes="reg-cell" Classes.changed="{Binding RegIEChanged}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="IE" Classes="reg-label" Width="24"/>
                                        <TextBlock Text="{Binding RegIE}" Classes="reg-value"/>
                                    </StackPanel>
                                </Border>
                                <Border Classes="reg-cell">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="PC" Classes="reg-label" Width="24"/>
                                        <TextBlock Text="{Binding PcHex}" Classes="reg-value" Foreground="{StaticResource HighlightPcTextBrush}"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <TextBlock Text="General (R0–RF)" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,4,0,0"/>

                            <ItemsControl ItemsSource="{Binding GeneralRegisters}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:RegisterItem">
                                        <Border Classes="reg-cell"
                                                Classes.active="{Binding IsActive}"
                                                Classes.changed="{Binding IsChanged}">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{Binding Name}" Classes="reg-label" Width="28"/>
                                                <TextBlock Text="{Binding Value}" Classes="reg-value"/>
                                                <TextBlock Text="P"
                                                           FontSize="10"
                                                           Foreground="{StaticResource HighlightPcTextBrush}"
                                                           IsVisible="{Binding IsProgramCounter}"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="X"
                                                           FontSize="10"
                                                           Foreground="{StaticResource AccentPrimaryBrush}"
                                                           IsVisible="{Binding IsDataPointer}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border Classes="reg-cell" Classes.changed="{Binding MachineStateChanged}" Margin="0,4,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="State" Classes="reg-label"/>
                                    <TextBlock Text="{Binding MachineState}"
                                               Classes="reg-value"
                                               Foreground="{StaticResource AccentSecondaryBrush}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Row="0" Grid.Column="1" Grid.RowSpan="3"
                          Width="4"
                          ResizeDirection="Columns"
                          Background="{StaticResource BorderSubtleBrush}"/>

            <Border Grid.Row="0" Grid.Column="2" Classes="cosmac-panel" Padding="6,6,6,4">
                <TabControl SelectedIndex="{Binding SelectedCodeTab}">
                    <TabItem Header="Disassembly">
                        <DockPanel Margin="4,8,4,4">
                            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                                <TextBlock Grid.Column="0" Text="Live trace at PC" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="BP @" VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBox Classes="cosmac-input"
                                             Text="{Binding BreakpointAddress}"
                                             PlaceholderText="0000"
                                             Width="72"/>
                                    <Button Content="Set"
                                            Command="{Binding ToggleBreakpointCommand}"
                                            Padding="8,4"
                                            VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Background="{StaticResource BackgroundEditorBrush}">
                                <ItemsControl ItemsSource="{Binding DisassemblyLines}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:DisassemblyLine">
                                            <Border Classes="disasm-line" Classes.current="{Binding IsCurrent}">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="{Binding Marker}"
                                                               Width="14"
                                                               FontFamily="{StaticResource MonoFont}"
                                                               Foreground="{StaticResource AccentSecondaryBrush}"/>
                                                    <TextBlock Text="●"
                                                               Foreground="{StaticResource BreakpointBrush}"
                                                               IsVisible="{Binding HasBreakpoint}"
                                                               FontSize="10"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Address}"
                                                               FontFamily="{StaticResource MonoFont}"
                                                               Foreground="{StaticResource SyntaxAddressBrush}"/>
                                                    <TextBlock Text="{Binding Opcode}"
                                                               FontFamily="{StaticResource MonoFont}"
                                                               Foreground="{StaticResource SyntaxOpcodeBrush}"
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Operand}"
                                                               FontFamily="{StaticResource MonoFont}"
                                                               Foreground="{StaticResource SyntaxOperandBrush}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </TabItem>
                    <TabItem Header="Assembler">
                        <DockPanel Margin="4,8,4,4">
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="0,0,0,8">
                                <Button Classes="cosmac-toolbar"
                                        Content="⚙ Assemble &amp; Load"
                                        Command="{Binding AssembleAndLoadCommand}"
                                        ToolTip.Tip="Assemble source and load into memory (F6)"/>
                                <TextBlock Text="; comments · ORG · DB · labels · R0-RF"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="11"/>
                            </StackPanel>
                            <Grid RowDefinitions="*,Auto,120">
                                <TextBox Grid.Row="0"
                                         Classes="cosmac-editor"
                                         Text="{Binding AssemblerSource}"
                                         AcceptsReturn="True"
                                         TextWrapping="NoWrap"
                                         MinHeight="180"/>
                                <TextBlock Grid.Row="1"
                                           Text="{Binding AssemblerErrors}"
                                           Foreground="{StaticResource BreakpointBrush}"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="11"
                                           Margin="0,6,0,4"
                                           TextWrapping="Wrap"/>
                                <DockPanel Grid.Row="2">
                                    <TextBlock Text="Listing"
                                               DockPanel.Dock="Top"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="11"
                                               Margin="0,0,0,4"/>
                                    <ScrollViewer Background="{StaticResource BackgroundEditorBrush}">
                                        <TextBox Classes="cosmac-editor"
                                                 FontSize="11"
                                                 Foreground="{StaticResource TextMutedBrush}"
                                                 Text="{Binding AssemblerListing}"
                                                 IsReadOnly="True"/>
                                    </ScrollViewer>
                                </DockPanel>
                            </Grid>
                        </DockPanel>
                    </TabItem>
                </TabControl>
            </Border>

            <GridSplitter Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                          Height="4"
                          ResizeDirection="Rows"
                          Background="{StaticResource BorderSubtleBrush}"/>

            <Border Grid.Row="2" Grid.Column="0" Classes="cosmac-panel">
                <DockPanel>
                    <TextBlock Text="Peripherals" Classes="section-header" DockPanel.Dock="Top"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <UniformGrid Columns="1" Rows="5">
                            <Border Classes="peripheral-badge">
                                <StackPanel>
                                    <TextBlock Text="UART" Classes="peripheral-label"/>
                                    <TextBlock Text="{Binding UartStatus}" Classes="peripheral-value"/>
                                </StackPanel>
                            </Border>
                            <Border Classes="peripheral-badge">
                                <StackPanel>
                                    <TextBlock Text="Timer" Classes="peripheral-label"/>
                                    <TextBlock Text="{Binding TimerStatus}" Classes="peripheral-value"/>
                                </StackPanel>
                            </Border>
                            <Border Classes="peripheral-badge">
                                <StackPanel>
                                    <TextBlock Text="GPIO" Classes="peripheral-label"/>
                                    <TextBlock Text="{Binding GpioStatus}" Classes="peripheral-value"/>
                                </StackPanel>
                            </Border>
                            <Border Classes="peripheral-badge">
                                <StackPanel>
                                    <TextBlock Text="Pixie" Classes="peripheral-label"/>
                                    <TextBlock Text="{Binding PixieStatus}" Classes="peripheral-value"/>
                                </StackPanel>
                            </Border>
                            <Border Classes="peripheral-badge">
                                <StackPanel>
                                    <TextBlock Text="Keyboard" Classes="peripheral-label"/>
                                    <TextBlock Text="{Binding KeyboardStatus}" Classes="peripheral-value"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Border Grid.Row="2" Grid.Column="2" Classes="cosmac-panel">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                        <TextBlock Grid.Column="0" Text="Memory" Classes="section-header" Margin="0"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="@" VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBox Classes="cosmac-input"
                                     Text="{Binding MemoryAddress}"
                                     PlaceholderText="0000"
                                     Width="72"/>
                            <Button Content="Go"
                                    Command="{Binding UpdateMemoryAddressCommand}"
                                    Padding="8,4"/>
                        </StackPanel>
                    </Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto"
                                  Background="{StaticResource BackgroundEditorBrush}">
                        <TextBox Classes="cosmac-editor"
                                 Text="{Binding MemoryDump}"
                                 IsReadOnly="True"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                    Classes="cosmac-panel"
                    Margin="6,0,6,6"
                    Padding="8,6">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="Trace Log"
                                   Classes="section-header"
                                   Margin="0"/>
                        <Button Grid.Column="1"
                                Command="{Binding ToggleTraceCommand}"
                                Padding="8,2"
                                VerticalAlignment="Center">
                            <Panel>
                                <TextBlock Text="▼ Expand" IsVisible="{Binding !IsTraceExpanded}"/>
                                <TextBlock Text="▲ Collapse" IsVisible="{Binding IsTraceExpanded}"/>
                            </Panel>
                        </Button>
                    </Grid>
                    <ScrollViewer IsVisible="{Binding IsTraceExpanded}"
                                  MaxHeight="140"
                                  VerticalScrollBarVisibility="Auto"
                                  Background="{StaticResource BackgroundEditorBrush}">
                        <TextBox Classes="cosmac-editor"
                                 FontSize="11"
                                 Foreground="{StaticResource TextMutedBrush}"
                                 Text="{Binding TraceLog}"
                                 IsReadOnly="True"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>