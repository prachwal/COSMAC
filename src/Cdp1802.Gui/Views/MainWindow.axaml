<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Cdp1802.Gui.ViewModels"
        xmlns:models="using:Cdp1802.Gui.Models"
        xmlns:controls="using:Cdp1802.Gui.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="860"
        x:Class="Cdp1802.Gui.Views.MainWindow"
        x:DataType="vm:Cdp1802ViewModel"
        Title="RCA CDP1802 (COSMAC) Emulator"
        Width="1280" Height="860"
        MinWidth="960" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundPrimaryBrush}">

    <Design.DataContext>
        <vm:Cdp1802ViewModel/>
    </Design.DataContext>

    <Window.KeyBindings>
        <KeyBinding Gesture="F6" Command="{Binding AssembleAndLoadCommand}"/>
        <KeyBinding Gesture="F7" Command="{Binding StepCommand}"/>
        <KeyBinding Gesture="F5" Command="{Binding ToggleRunCommand}"/>
        <KeyBinding Gesture="F9" Command="{Binding ResetCommand}"/>
    </Window.KeyBindings>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Load Binary..." Click="OnLoadFile"/>
                <MenuItem Header="_Assemble &amp; Load (F6)" Command="{Binding AssembleAndLoadCommand}"/>
                <Separator/>
                <MenuItem Header="_Settings..." Click="OnSettings"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="OnExit"/>
            </MenuItem>
            <MenuItem Header="_Examples">
                <MenuItem Header="Hello Byte" Command="{Binding LoadExampleCommand}" CommandParameter="hello"/>
                <MenuItem Header="Counter Loop" Command="{Binding LoadExampleCommand}" CommandParameter="counter"/>
                <MenuItem Header="Q Toggle" Command="{Binding LoadExampleCommand}" CommandParameter="blink"/>
                <MenuItem Header="Add / Subtract" Command="{Binding LoadExampleCommand}" CommandParameter="add_test"/>
                <MenuItem Header="Branch Demo" Command="{Binding LoadExampleCommand}" CommandParameter="branch_demo"/>
            </MenuItem>
            <MenuItem Header="_Emulation">
                <MenuItem Header="_Step (F7)" Command="{Binding StepCommand}"/>
                <MenuItem Header="_Run / Stop (F5)" Command="{Binding ToggleRunCommand}"/>
                <MenuItem Header="_Reset (F9)" Command="{Binding ResetCommand}"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Trace Log" Command="{Binding ToggleTraceCommand}"/>
                <MenuItem Header="_Light Theme" ToggleType="CheckBox" IsChecked="{Binding IsLightTheme}"/>
                <MenuItem Header="_Enable Heatmap" ToggleType="CheckBox" Command="{Binding ToggleHeatmapCommand}"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Click="OnAbout"/>
            </MenuItem>
        </Menu>

        <Border DockPanel.Dock="Top"
                Background="{DynamicResource BackgroundPanelBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,6">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <Button Classes="cosmac-toolbar" Content="▶ Step" Command="{Binding StepCommand}" ToolTip.Tip="Execute one instruction (F7)"/>
                <Button Classes="cosmac-toolbar" Content="◀ Back" Command="{Binding StepBackCommand}" ToolTip.Tip="Undo last instruction"/>
                <Panel>
                    <Button Classes="cosmac-toolbar run"
                            Content="⏵ Run"
                            Command="{Binding RunCommand}"
                            IsVisible="{Binding !IsRunning}"
                            ToolTip.Tip="Start emulation (F5)"/>
                    <Button Classes="cosmac-toolbar stop"
                            Content="⏹ Stop"
                            Command="{Binding StopCommand}"
                            IsVisible="{Binding IsRunning}"
                            ToolTip.Tip="Stop emulation (F5)"/>
                </Panel>
                <Button Classes="cosmac-toolbar" Content="↺ Reset" Command="{Binding ResetCommand}" ToolTip.Tip="Reset CPU (F9)"/>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource StatusBarBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,6">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" Margin="16,0">
                    <TextBlock Text="State:" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding MachineState}"
                               Foreground="{DynamicResource AccentSecondaryBrush}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" Margin="16,0">
                    <TextBlock Text="PC:" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding PcHex}"
                               Foreground="{DynamicResource HighlightPcTextBrush}"
                               FontFamily="{DynamicResource MonoFont}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6" Margin="16,0,0,0">
                    <TextBlock Text="Cycles:" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalCycles}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontFamily="{DynamicResource MonoFont}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="6" Margin="16,0,0,0"
                            IsVisible="{Binding IsRunning}">
                    <TextBlock Text="IPS:" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Perf.Ips, StringFormat='{}{0:N0}'}"
                               FontFamily="{DynamicResource MonoFont}"
                               Foreground="{DynamicResource AccentSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Perf.EffectiveMhz, StringFormat='{}{0:F2} MHz'}"
                               Foreground="{DynamicResource TextMutedBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Margin="2"
              ColumnDefinitions="Auto,4,*"
              RowDefinitions="*,4,168,Auto">

            <Border Grid.Row="0" Grid.Column="0" Classes="cosmac-panel" MinWidth="220" MaxWidth="360">
                <DockPanel>
                    <TextBlock Text="Registers" Classes="section-header" DockPanel.Dock="Top"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Control" Foreground="{DynamicResource TextMutedBrush}" FontSize="11"/>

                            <UniformGrid Columns="2" Rows="4">
                                <Border Classes="reg-cell" Classes.changed="{Binding RegDChanged}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="D" Classes="reg-label" Width="24"/>
                                        <TextBlock Text="{Binding RegD}" Classes="reg-value"/>
                                    </StackPanel>
                                </Border>
                                <Border Classes="reg-cell" Classes.changed="{Binding RegDFChanged}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="DF" Classes="reg-label" Width="24"/>
                                        <TextBlock Text="{Binding RegDF}" Classes="reg-value"/>
                                    </StackPanel>
                                </Border>
                                <Border Classes="reg-cell" Classes.changed="{Binding RegPChanged}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="P" Classes="reg-label" Width="24"/>
                                        <TextBlock Text="{Binding RegP}" Classes="reg-value"/>
                                    </StackPanel>
                                </Border>
                                <Border Classes="reg-cell" Classes.changed="{Binding RegXChanged}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="X" Classes="reg-label" Width="24"/>
                                        <TextBlock Text="{Binding RegX}" Classes="reg-value"/>
                                    </StackPanel>
                                </Border>
                                <Border Classes="reg-cell" Classes.changed="{Binding RegTChanged}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="T" Classes="reg-label" Width="24"/>
                                        <TextBlock Text="{Binding RegT}" Classes="reg-value"/>
                                    </StackPanel>
                                </Border>
                                <Border Classes="reg-cell" Classes.changed="{Binding RegQChanged}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="Q" Classes="reg-label" Width="24"/>
                                        <TextBlock Text="{Binding RegQ}" Classes="reg-value"/>
                                    </StackPanel>
                                </Border>
                                <Border Classes="reg-cell" Classes.changed="{Binding RegIEChanged}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="IE" Classes="reg-label" Width="24"/>
                                        <TextBlock Text="{Binding RegIE}" Classes="reg-value"/>
                                    </StackPanel>
                                </Border>
                                <Border Classes="reg-cell">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="PC" Classes="reg-label" Width="24"/>
                                        <TextBlock Text="{Binding PcHex}" Classes="reg-value" Foreground="{DynamicResource HighlightPcTextBrush}"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <TextBlock Text="General (R0–RF)" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" Margin="0,4,0,0"/>

                            <ItemsControl ItemsSource="{Binding GeneralRegisters}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:RegisterItem">
                                        <Border Classes="reg-cell"
                                                Classes.active="{Binding IsActive}"
                                                Classes.changed="{Binding IsChanged}">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{Binding Name}" Classes="reg-label" Width="28"/>
                                                <TextBlock Text="{Binding Value}" Classes="reg-value"/>
                                                <TextBlock Text="P"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource HighlightPcTextBrush}"
                                                           IsVisible="{Binding IsProgramCounter}"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="X"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource AccentPrimaryBrush}"
                                                           IsVisible="{Binding IsDataPointer}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border Classes="reg-cell" Classes.changed="{Binding MachineStateChanged}" Margin="0,4,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="State" Classes="reg-label"/>
                                    <TextBlock Text="{Binding MachineState}"
                                               Classes="reg-value"
                                               Foreground="{DynamicResource AccentSecondaryBrush}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Row="0" Grid.Column="1" Grid.RowSpan="3"
                          Width="4"
                          ResizeDirection="Columns"
                          Background="{DynamicResource BorderSubtleBrush}"/>

            <Border Grid.Row="0" Grid.Column="2" Classes="cosmac-panel" Padding="6,6,6,4">
                <TabControl SelectedIndex="{Binding SelectedCodeTab}">
                    <TabItem Header="Disassembly">
                        <DockPanel Margin="4,8,4,4">
                            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                                <TextBlock Grid.Column="0" Text="Live trace at PC" Foreground="{DynamicResource TextMutedBrush}" FontSize="11"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="BP @" VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}"/>
                                    <TextBox Classes="cosmac-input"
                                             Text="{Binding BreakpointAddress}"
                                             PlaceholderText="0000"
                                             Width="72"/>
                                    <Button Content="Set"
                                            Command="{Binding ToggleBreakpointCommand}"
                                            Padding="8,4"
                                            VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Background="{DynamicResource BackgroundEditorBrush}">
                                <ItemsControl ItemsSource="{Binding DisassemblyLines}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:DisassemblyLine">
                                            <Button Background="Transparent" Padding="2,1"
                                                    Command="{Binding $parent[ItemsControl].((vm:Cdp1802ViewModel)DataContext).ToggleBreakpointAtPcCommand}"
                                                    CommandParameter="{Binding Pc}"
                                                    Margin="0,1">
                                                <Border Classes="disasm-line" Classes.current="{Binding IsCurrent}" Classes.breakpoint="{Binding HasBreakpoint}">
                                                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="4,2">
                                                        <TextBlock Text="{Binding Marker}" Foreground="{DynamicResource BreakpointBrush}" FontSize="9" FontWeight="Bold"/>
                                                        <TextBlock Text="●"
                                                                   Foreground="{DynamicResource BreakpointBrush}"
                                                                   IsVisible="{Binding HasBreakpoint}"
                                                                   FontSize="10"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Cycles}" FontSize="9" Foreground="{DynamicResource TextMutedBrush}"/>
                                                        <TextBlock Text="{Binding Address}"
                                                                   FontFamily="{DynamicResource MonoFont}"
                                                                   Foreground="{DynamicResource SyntaxAddressBrush}"/>
                                                        <TextBlock Text="{Binding Opcode}"
                                                                   FontFamily="{DynamicResource MonoFont}"
                                                                   Foreground="{DynamicResource SyntaxOpcodeBrush}"
                                                                   FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding Operand}"
                                                                   FontFamily="{DynamicResource MonoFont}"
                                                                   Foreground="{DynamicResource SyntaxOperandBrush}"/>
                                                        <TextBlock Text="{Binding BranchTarget}" FontSize="9" Foreground="{DynamicResource AccentSecondaryBrush}"/>
                                                    </StackPanel>
                                                </Border>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </TabItem>
                    <TabItem Header="Assembler">
                        <DockPanel Margin="4,8,4,4">
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="0,0,0,8">
                                <Button Classes="cosmac-toolbar"
                                        Content="⚙ Assemble &amp; Load"
                                        Command="{Binding AssembleAndLoadCommand}"
                                        ToolTip.Tip="Assemble source and load into memory (F6)"/>
                                <TextBlock Text="; comments · ORG · DB · labels · R0-RF"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           FontSize="11"/>
                            </StackPanel>
                            <Grid RowDefinitions="*,Auto,120">
                                <TextBox Grid.Row="0"
                                         Classes="cosmac-editor"
                                         Text="{Binding AssemblerSource}"
                                         AcceptsReturn="True"
                                         TextWrapping="NoWrap"
                                         MinHeight="180"/>
                                <Border Grid.Row="1" Classes="cosmac-panel" IsVisible="{Binding HasErrors}"
                                        BorderBrush="{DynamicResource BreakpointBrush}"
                                        Margin="0,6,0,4" Padding="6">
                                    <ItemsControl ItemsSource="{Binding AssemblerErrorItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:AssemblerError">
                                                <TextBlock Text="{Binding Display}"
                                                           Foreground="{DynamicResource BreakpointBrush}"
                                                           FontFamily="{DynamicResource MonoFont}"
                                                           FontSize="11"
                                                           Margin="0,2"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                                <DockPanel Grid.Row="2">
                                    <TextBlock Text="Listing"
                                               DockPanel.Dock="Top"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               FontSize="11"
                                               Margin="0,0,0,4"/>
                                    <ScrollViewer Background="{DynamicResource BackgroundEditorBrush}">
                                        <TextBox Classes="cosmac-editor"
                                                 FontSize="11"
                                                 Foreground="{DynamicResource TextMutedBrush}"
                                                 Text="{Binding AssemblerListing}"
                                                 IsReadOnly="True"/>
                                    </ScrollViewer>
                                </DockPanel>
                            </Grid>
                        </DockPanel>
                    </TabItem>
                    <TabItem Header="Watch/Breaks">
                        <StackPanel Margin="6" Spacing="8">
                            <TextBlock Text="Watchpoints" FontWeight="SemiBold" Foreground="{DynamicResource AccentPrimaryBrush}"/>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBox Classes="cosmac-input" Text="{Binding WatchpointAddress}" Width="72" PlaceholderText="addr"/>
                                <Button Content="Add Watch" Command="{Binding AddWatchpointCommand}"/>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding Watchpoints}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:WatchpointItem">
                                        <Border Classes="peripheral-badge" Padding="6">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{Binding Address}" FontFamily="{DynamicResource MonoFont}"/>
                                                <TextBlock Text="{Binding OldValue, StringFormat='{}{0} → '}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10"/>
                                                <TextBlock Text="{Binding NewValue}" Foreground="{DynamicResource AccentSecondaryBrush}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="Conditional Breakpoints" FontWeight="SemiBold" Foreground="{DynamicResource AccentPrimaryBrush}" Margin="0,8,0,0"/>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBox Classes="cosmac-input" Text="{Binding BreakpointAddress}" Width="72" PlaceholderText="addr"/>
                                <TextBox Classes="cosmac-input" Text="{Binding BreakpointCondition}" Width="120" PlaceholderText="D == 0xFF"/>
                                <Button Content="Add BP" Command="{Binding AddConditionalBreakpointCommand}"/>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding Breakpoints}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:BreakpointItem">
                                        <Border Classes="peripheral-badge" Padding="6">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <TextBlock Text="{Binding Address}" FontFamily="{DynamicResource MonoFont}"/>
                                                <TextBlock Text="{Binding Condition}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </TabItem>
                    <TabItem Header="Heatmap">
                        <Grid>
                            <controls:MemoryHeatmap Heat="{Binding HeatSnapshot}"/>
                        </Grid>
                    </TabItem>
                    <TabItem Header="Peripherals">
                        <StackPanel Margin="6" Spacing="12">
                            <StackPanel>
                                <TextBlock Text="Display (Pixie)" FontWeight="SemiBold" Foreground="{DynamicResource AccentPrimaryBrush}"/>
                                <Border Background="{DynamicResource BackgroundEditorBrush}" Padding="4" CornerRadius="4">
                                    <controls:PixieDisplay Source="{Binding PixieBitmap}" Height="128"/>
                                </Border>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="UART Terminal" FontWeight="SemiBold"/>
                                <TextBox IsReadOnly="True" Height="80" Text="{Binding UartConsole}"/>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Timer" FontWeight="SemiBold"/>
                                <ProgressBar Value="{Binding TimerCounter}" Maximum="{Binding TimerCompare}"/>
                                <TextBlock Text="{Binding TimerStatus}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </TabItem>
                </TabControl>
            </Border>

            <GridSplitter Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                          Height="4"
                          ResizeDirection="Rows"
                          Background="{DynamicResource BorderSubtleBrush}"/>

            <Border Grid.Row="2" Grid.Column="0" Classes="cosmac-panel"
                    IsVisible="{Binding !IsCompact}">
                <DockPanel>
                    <TextBlock Text="Peripherals" Classes="section-header" DockPanel.Dock="Top"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <UniformGrid Columns="1" Rows="5">
                            <Border Classes="peripheral-badge">
                                <StackPanel>
                                    <TextBlock Text="UART" Classes="peripheral-label"/>
                                    <TextBlock Text="{Binding UartStatus}" Classes="peripheral-value"/>
                                </StackPanel>
                            </Border>
                            <Border Classes="peripheral-badge">
                                <StackPanel>
                                    <TextBlock Text="Timer" Classes="peripheral-label"/>
                                    <TextBlock Text="{Binding TimerStatus}" Classes="peripheral-value"/>
                                </StackPanel>
                            </Border>
                            <Border Classes="peripheral-badge">
                                <StackPanel>
                                    <TextBlock Text="GPIO" Classes="peripheral-label"/>
                                    <TextBlock Text="{Binding GpioStatus}" Classes="peripheral-value"/>
                                </StackPanel>
                            </Border>
                            <Border Classes="peripheral-badge">
                                <StackPanel>
                                    <TextBlock Text="Pixie" Classes="peripheral-label"/>
                                    <TextBlock Text="{Binding PixieStatus}" Classes="peripheral-value"/>
                                </StackPanel>
                            </Border>
                            <Border Classes="peripheral-badge">
                                <StackPanel>
                                    <TextBlock Text="Keyboard" Classes="peripheral-label"/>
                                    <TextBlock Text="{Binding KeyboardStatus}" Classes="peripheral-value"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Border Grid.Row="2" Grid.Column="2" Classes="cosmac-panel">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                        <TextBlock Grid.Column="0" Text="Memory" Classes="section-header" Margin="0"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="@" VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}"/>
                            <TextBox Classes="cosmac-input"
                                     Text="{Binding MemoryAddress}"
                                     PlaceholderText="0000"
                                     Width="72"/>
                            <Button Content="Go"
                                    Command="{Binding UpdateMemoryAddressCommand}"
                                    Padding="8,4"/>
                        </StackPanel>
                    </Grid>
                    <Border Background="{DynamicResource BackgroundEditorBrush}"
                            CornerRadius="4"
                            Padding="8,4">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" ColumnDefinitions="60,Auto,8,Auto,Auto,Auto,Auto,Auto,Auto,Auto,8,Auto,Auto,Auto,Auto,Auto,Auto,Auto,8,*"
                                  Margin="0,0,0,4">
                                <TextBlock Grid.Column="0" Text="Addr" Classes="hex-header"/>
                                <TextBlock Grid.Column="2" Text="0" Classes="hex-header"/>
                                <TextBlock Grid.Column="3" Text="1" Classes="hex-header"/>
                                <TextBlock Grid.Column="4" Text="2" Classes="hex-header"/>
                                <TextBlock Grid.Column="5" Text="3" Classes="hex-header"/>
                                <TextBlock Grid.Column="6" Text="4" Classes="hex-header"/>
                                <TextBlock Grid.Column="7" Text="5" Classes="hex-header"/>
                                <TextBlock Grid.Column="8" Text="6" Classes="hex-header"/>
                                <TextBlock Grid.Column="9" Text="7" Classes="hex-header"/>
                                <TextBlock Grid.Column="11" Text="8" Classes="hex-header"/>
                                <TextBlock Grid.Column="12" Text="9" Classes="hex-header"/>
                                <TextBlock Grid.Column="13" Text="A" Classes="hex-header"/>
                                <TextBlock Grid.Column="14" Text="B" Classes="hex-header"/>
                                <TextBlock Grid.Column="15" Text="C" Classes="hex-header"/>
                                <TextBlock Grid.Column="16" Text="D" Classes="hex-header"/>
                                <TextBlock Grid.Column="17" Text="E" Classes="hex-header"/>
                                <TextBlock Grid.Column="18" Text="F" Classes="hex-header"/>
                                <TextBlock Grid.Column="20" Text="ASCII" Classes="hex-header"/>
                            </Grid>
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding MemoryRows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="60,Auto,8,Auto,Auto,Auto,Auto,Auto,Auto,Auto,8,Auto,Auto,Auto,Auto,Auto,Auto,Auto,8,*"
                                                  Margin="0,1">
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Address}"
                                                           Classes="hex-addr"/>
                                                <TextBlock Grid.Column="2" Text="{Binding B0}" Classes="hex-byte"/>
                                                <TextBlock Grid.Column="3" Text="{Binding B1}" Classes="hex-byte"/>
                                                <TextBlock Grid.Column="4" Text="{Binding B2}" Classes="hex-byte"/>
                                                <TextBlock Grid.Column="5" Text="{Binding B3}" Classes="hex-byte"/>
                                                <TextBlock Grid.Column="6" Text="{Binding B4}" Classes="hex-byte"/>
                                                <TextBlock Grid.Column="7" Text="{Binding B5}" Classes="hex-byte"/>
                                                <TextBlock Grid.Column="8" Text="{Binding B6}" Classes="hex-byte"/>
                                                <TextBlock Grid.Column="9" Text="{Binding B7}" Classes="hex-byte"/>
                                                <TextBlock Grid.Column="11" Text="{Binding B8}" Classes="hex-byte"/>
                                                <TextBlock Grid.Column="12" Text="{Binding B9}" Classes="hex-byte"/>
                                                <TextBlock Grid.Column="13" Text="{Binding BA}" Classes="hex-byte"/>
                                                <TextBlock Grid.Column="14" Text="{Binding BB}" Classes="hex-byte"/>
                                                <TextBlock Grid.Column="15" Text="{Binding BC}" Classes="hex-byte"/>
                                                <TextBlock Grid.Column="16" Text="{Binding BD}" Classes="hex-byte"/>
                                                <TextBlock Grid.Column="17" Text="{Binding BE}" Classes="hex-byte"/>
                                                <TextBlock Grid.Column="18" Text="{Binding BF}" Classes="hex-byte"/>
                                                <TextBlock Grid.Column="20"
                                                           Text="{Binding Ascii}"
                                                           Classes="hex-ascii"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </DockPanel>
            </Border>

            <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                    Classes="cosmac-panel"
                    Margin="6,0,6,6"
                    Padding="8,6">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="Trace Log"
                                   Classes="section-header"
                                   Margin="0"/>
                        <Button Grid.Column="1"
                                Command="{Binding ToggleTraceCommand}"
                                Padding="8,2"
                                VerticalAlignment="Center">
                            <Panel>
                                <TextBlock Text="▼ Expand" IsVisible="{Binding !IsTraceExpanded}"/>
                                <TextBlock Text="▲ Collapse" IsVisible="{Binding IsTraceExpanded}"/>
                            </Panel>
                        </Button>
                    </Grid>
                    <ScrollViewer IsVisible="{Binding IsTraceExpanded}"
                                  MaxHeight="140"
                                  VerticalScrollBarVisibility="Auto"
                                  Background="{DynamicResource BackgroundEditorBrush}">
                        <TextBox Classes="cosmac-editor"
                                 FontSize="11"
                                 Foreground="{DynamicResource TextMutedBrush}"
                                 Text="{Binding TraceLog}"
                                 IsReadOnly="True"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
